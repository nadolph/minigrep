<%- include('partials/header', { title: 'Register' }) %>

<main style="max-width:480px;margin:3rem auto;padding:0 1.25rem">
  <h1 class="page-title">Join the Cook-Off</h1>

  <% if (error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="card">
    <form method="POST" action="/register">

      <p style="color:var(--light);margin-bottom:1.25rem;font-size:.95rem">Are you competing or judging?</p>

      <div class="role-cards">
        <div class="role-card">
          <input type="radio" name="role" id="role-contestant" value="contestant" required>
          <label for="role-contestant">
            <span class="role-icon">🥩</span>
            <span class="role-name">Contestant</span>
            <span class="role-desc">I'm cooking a steak and want to win</span>
          </label>
        </div>
        <div class="role-card">
          <input type="radio" name="role" id="role-taster" value="taster">
          <label for="role-taster">
            <span class="role-icon">👅</span>
            <span class="role-name">Taster</span>
            <span class="role-desc">I'm here to taste and vote on steaks</span>
          </label>
        </div>
      </div>

      <div class="form-group">
        <label for="username">Username</label>
        <input id="username" type="text" name="username" required autocomplete="username" placeholder="e.g. SteakMaster3000">
      </div>
      <div class="form-group">
        <label for="email">Email</label>
        <input id="email" type="email" name="email" required autocomplete="email">
      </div>
      <div class="form-group">
        <label for="password">Password <span style="color:var(--light);font-size:.85rem">(min 6 characters)</span></label>
        <input id="password" type="password" name="password" required autocomplete="new-password" minlength="6">
      </div>

      <button class="btn btn-primary btn-full" type="submit">Create Account</button>
    </form>
    <p class="form-footer">Already have an account? <a href="/login">Log in</a></p>
  </div>
</main>

<%- include('partials/footer') %>
